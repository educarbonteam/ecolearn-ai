# EcoLearn AI Environment Variables
# Copy this file to .env and fill in your actual values

# ==================== DATABASE ====================
DATABASE_URL=postgresql://ecolearn:ecolearn2024@db:5432/ecolearn_db

# ==================== SECURITY ====================
SECRET_KEY=your-secret-key-change-in-production-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== OPENAI API ====================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ==================== REFORESTATION API ====================
TREE_API_URL=https://api.tree-nation.com/v1
TREE_API_KEY=your-tree-nation-api-key

# ==================== APPLICATION ====================
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# ==================== AWS (Production) ====================
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
ECR_REGISTRY=your-account-id.dkr.ecr.eu-west-1.amazonaws.com

# ==================== MONITORING ====================
PROMETHEUS_ENABLED=True
GRAFANA_ADMIN_PASSWORD=admin

# ==================== FRONTEND ====================
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ENVIRONMENT=development
